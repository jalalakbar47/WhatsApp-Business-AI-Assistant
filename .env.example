# Meta WhatsApp Business API
WHATSAPP_ACCESS_TOKEN=             # Permanent access token from Meta Business > System Users > Generate Token
WHATSAPP_PHONE_NUMBER_ID=         # Phone Number ID from Meta App > WhatsApp > API Setup
WHATSAPP_VERIFY_TOKEN=            # Any string you choose (e.g. "myverifytoken123") - used to verify webhook

# AI Model settings
GEMINI_API_KEY=                   # Google AI Studio API key (starts with AIza... or AQ...)
AI_MODEL=gemini-3.5-flash         # Direct Gemini model to use (e.g., gemini-3.5-flash, gemini-2.5-flash)

# Supabase Configurations
NEXT_PUBLIC_SUPABASE_URL=         # Supabase project URL (e.g. https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=    # Supabase anon/public key (for frontend)
SUPABASE_SERVICE_ROLE_KEY=        # Supabase service role key (for backend/webhook)

# App Config
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000